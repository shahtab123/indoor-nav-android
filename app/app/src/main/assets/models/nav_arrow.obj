v   0.00  0.06  0.22
# Wing back (wide)
v  -0.14  0.00  0.00
v  -0.14  0.06  0.00
v   0.14  0.00  0.00
v   0.14  0.06  0.00
# Shaft
v  -0.045 0.00  0.00
v  -0.045 0.06  0.00
v   0.045 0.00  0.00
v   0.045 0.06  0.00
v  -0.045 0.00 -0.16
v  -0.045 0.06 -0.16
v   0.045 0.00 -0.16
v   0.045 0.06 -0.16

